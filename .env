# =============================================
# CONFIGURACIÓN GENERAL
# =============================================
NODE_ENV=development
URL_APLICACION=http://localhost:3000
NOMBRE_APLICACION=Sistema de Horarios UNT
VERSION=1.0.0
# Redis (COMENTADO - no necesario)
# REDIS_URL="redis://localhost:6379"
# =============================================
# BASE DE DATOS (PostgreSQL con Docker)
# =============================================
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL="postgresql://postgres:123456@localhost:5432/horarios_unt?schema=public"

# =============================================
# REDIS (Caché y WebSocket)
# =============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
NEXT_PUBLIC_API_URL="http://localhost:3000"

# =============================================
# JWT (Autenticación)
# =============================================
JWT_SECRET="horarios-2025"
JWT_EXPIRACION=8h
JWT_REFRESH_EXPIRACION=7d

# =============================================
# CORREO ELECTRÓNICO (SMTP)
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PUERTO=587
SMTP_SEGURO=false
SMTP_USUARIO=sistemas@unitru.edu.pe
SMTP_CONTRASENA=contraseña_aplicacion_google
SMTP_REMITENTE=sistemas@unitru.edu.pe

# =============================================
# WHATSAPP BUSINESS API (Meta)
# =============================================
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=tu_token_de_acceso
WHATSAPP_NUMERO_TELEFONO_ID=tu_numero_telefono_id
WHATSAPP_VERIFY_TOKEN=token_verificacion_webhook

# =============================================
# TELEGRAM BOT
# =============================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_USERNAME=UNT_Horarios_Bot
TELEGRAM_WEBHOOK_URL=https://horarios.unitru.edu.pe/api/telegram/webhook

# =============================================
# PUPPETEER (Generación PDF)
# =============================================
# En Windows con Laragon, usar la ruta de Chrome instalado
PUPPETEER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# =============================================
# SEGURIDAD
# =============================================
CORS_ORIGEN=http://localhost:3000
LIMITE_TASA_VENTANA=100
LIMITE_TASA_MINUTO=1000
SESSION_TIMEOUT=480

# =============================================
# LOGGING
# =============================================
LOG_NIVEL=debug
LOG_ARCHIVO=logs/aplicacion.log
