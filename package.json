{
  "name": "horarios-unt",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Horarios - Escuela de Ingeniería de Sistemas - UNT",
  "private": true,
  "engines": {
    "node": ">=18.17.0 <21.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "db:export": "ts-node --project tsconfig-scripts.json scripts/exportar-datos.ts",
    "db:import": "ts-node --project tsconfig-scripts.json scripts/importar-datos.ts",
    "ventanas:estandar": "ts-node --project tsconfig-scripts.json scripts/configuracion-ventanas-estandar.ts",
    "db:exportar-sql": "ts-node --project tsconfig-scripts.json scripts/exportar-sql-completo.ts",
    "db:clean": "ts-node --project tsconfig-scripts.json scripts/limpiar-base-datos.ts",
    "db:insert-reales": "ts-node --project tsconfig-scripts.json scripts/insertar-datos-reales.ts",
    "db:insert-admin": "ts-node --project tsconfig-scripts.json scripts/insertar-admin.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "csv-parse": "^5.5.3",
    "date-fns": "^3.3.1",
    "exceljs": "^4.4.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.321.0",
    "next": "^14.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "pg": "^8.21.0",
    "postcss": "^8.4.33",
    "puppeteer": "^21.9.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "react-toastify": "^10.0.4",
    "recharts": "^2.10.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.5.10",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "jest": "^29.7.0",
    "playwright": "^1.41.1",
    "prettier": "^3.2.4",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2"
  }
}
